#!/usr/bin/env sh
set -eu

if ! command -v flutter >/dev/null 2>&1 || ! command -v dart >/dev/null 2>&1; then
  for FLUTTER_DIR in \
    "$HOME/Development/flutter/bin" \
    "$HOME/flutter/bin" \
    "/opt/homebrew/Caskroom/flutter/latest/flutter/bin"
  do
    if [ -x "$FLUTTER_DIR/flutter" ] && [ -x "$FLUTTER_DIR/dart" ]; then
      PATH="$FLUTTER_DIR:$PATH"
      export PATH
      break
    fi
  done
fi

DART_BIN=$(command -v dart || true)
FLUTTER_BIN=$(command -v flutter || true)

if [ -z "$DART_BIN" ] || [ -z "$FLUTTER_BIN" ]; then
  echo "[pre-commit] dart/flutter command not found in PATH."
  echo "[pre-commit] Ensure Flutter SDK bin is available for GUI apps as well."
  exit 1
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | tr '\n' ' ')
if [ -z "${STAGED_FILES}" ]; then
  exit 0
fi

DART_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.dart$' || true)
if [ -n "${DART_FILES}" ]; then
  echo "[pre-commit] Checking Dart formatting for staged files..."
  "$DART_BIN" format --output=none --set-exit-if-changed ${DART_FILES}
fi

ANALYZE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(lib|test)/.*\.dart$' || true)
if [ -n "${ANALYZE_FILES}" ]; then
  echo "[pre-commit] Analyzing staged Dart files..."
  "$FLUTTER_BIN" analyze ${ANALYZE_FILES}
fi
